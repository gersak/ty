{
  "name": "tyrell-uix-example",
  "version": "1.0.0",
  "dependencies": {
    "tyrell-components": "1.0.0-TC7",
    "tyrell-react": "1.0.0-TC10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@tailwindcss/forms": "^0.5.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "shadow-cljs": "^3.2.0",
    "tailwindcss": "4.1"
  },
  "scripts": {
    "postinstall": "mkdir -p public/css && cp node_modules/tyrell-components/css/tyrell.css public/css/tyrell.css",
    "css:build": "@tailwindcss/cli -i src/input.css -o public/css/app.css",
    "css:watch": "@tailwindcss/cli -i src/input.css -o public/css/app.css --watch",
    "dev": "shadow-cljs -A:dev watch dev"
  }
}
